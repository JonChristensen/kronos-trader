FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy workspace definition
COPY pyproject.toml uv.lock* ./

# Copy all packages needed by agent
COPY packages/shared packages/shared
COPY packages/alpaca_client packages/alpaca_client
COPY packages/kronos_model packages/kronos_model
COPY packages/signal_engine packages/signal_engine
COPY services/agent services/agent

# Install dependencies (includes PyTorch for CPU)
RUN uv sync --frozen --package kt-agent 2>/dev/null || uv sync --package kt-agent

CMD ["/app/.venv/bin/python", "-m", "kt_agent.main"]
